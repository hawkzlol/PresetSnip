<Window x:Class="PresetSnip.SelectionOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pick Points"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="#66100B1D"
        Cursor="Cross"
        KeyDown="Window_KeyDown"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        SourceInitialized="Window_SourceInitialized">
    <Grid>
        <Canvas x:Name="OverlayCanvas" Background="#66100B1D">
            <Border x:Name="InstructionPanel"
                    Canvas.Left="24"
                    Canvas.Top="24"
                    Background="#F7171229"
                    BorderBrush="#AA7C3AED"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="18,14">
                <StackPanel>
                    <TextBlock x:Name="InstructionTitle"
                               Text="Click point A"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="#F5F3FF" />
                    <TextBlock x:Name="InstructionText"
                               Margin="0,4,0,0"
                               Text="Click the first corner of the capture area. Press Esc to cancel."
                               FontSize="13"
                               Foreground="#E9D5FF" />
                </StackPanel>
            </Border>

            <Rectangle x:Name="SelectionRectangle"
                       Visibility="Collapsed"
                       Stroke="#C084FC"
                       StrokeThickness="2"
                       Fill="#337C3AED" />

            <Ellipse x:Name="PointAMarker"
                     Visibility="Collapsed"
                     Width="14"
                     Height="14"
                     Fill="#C084FC"
                     Stroke="White"
                     StrokeThickness="2" />

            <Ellipse x:Name="PointBMarker"
                     Visibility="Collapsed"
                     Width="14"
                     Height="14"
                     Fill="#A855F7"
                     Stroke="White"
                     StrokeThickness="2" />
        </Canvas>
    </Grid>
</Window>
