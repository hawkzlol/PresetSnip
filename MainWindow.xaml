<Window x:Class="PresetSnip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PresetSnip"
        Height="650"
        MinHeight="420"
        Width="820"
        MinWidth="740"
        Background="#0F1020"
        FontFamily="Segoe UI"
        SourceInitialized="Window_SourceInitialized"
        Closing="Window_Closing"
        PreviewKeyDown="Window_PreviewKeyDown">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E9D5FF" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#B9A8D8" />
            <Setter Property="FontSize" Value="13" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="#6D28D9" />
            <Setter Property="Background" Value="#24133F" />
            <Setter Property="Foreground" Value="#F5F3FF" />
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#7C3AED" />
            <Setter Property="BorderBrush" Value="#A855F7" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderBrush" Value="#6D28D9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#171229" />
            <Setter Property="Foreground" Value="#F5F3FF" />
            <Setter Property="CaretBrush" Value="#C084FC" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#F5F3FF" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="TickFrequency" Value="10" />
            <Setter Property="IsSnapToTickEnabled" Value="False" />
        </Style>
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalFirst"
                  CanContentScroll="False">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,22">
            <TextBlock Text="PresetSnip"
                       FontSize="30"
                       FontWeight="Bold"
                       Foreground="#F5F3FF" />
            <TextBlock Text="Capture the same preset screen area instantly with one global hotkey."
                       Margin="0,4,0,0"
                       FontSize="14"
                       Foreground="#B9A8D8" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#171229"
                    BorderBrush="#3B1A66"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Save directory" Style="{StaticResource LabelText}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DirectoryTextBox"
                                 Grid.Column="0"
                                 VerticalContentAlignment="Center"
                                 TextChanged="DirectoryTextBox_TextChanged" />
                        <Button Grid.Column="2"
                                Content="Browse"
                                Click="BrowseButton_Click" />
                    </Grid>

                    <TextBlock Text="Hotkey"
                               Style="{StaticResource LabelText}"
                               Margin="0,22,0,8" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                MinHeight="42"
                                BorderBrush="#6D28D9"
                                BorderThickness="1"
                                Background="#100B1D"
                                CornerRadius="6"
                                Padding="12,9">
                            <TextBlock x:Name="HotKeyText"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Foreground="#F5F3FF" />
                        </Border>
                        <Button x:Name="RecordButton"
                                Grid.Column="2"
                                Content="Start Record"
                                Click="RecordButton_Click" />
                    </Grid>

                    <TextBlock Text="Capture area"
                               Style="{StaticResource LabelText}"
                               Margin="0,22,0,8" />
                    <Border BorderBrush="#6D28D9"
                            BorderThickness="1"
                            Background="#100B1D"
                            CornerRadius="6"
                            Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="RegionText"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#F5F3FF" />
                            <TextBlock x:Name="PointText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Border>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PickPointsButton"
                                Grid.Column="0"
                                Content="Pick 2 Points"
                                Style="{StaticResource PrimaryButton}"
                                Click="PickPointsButton_Click" />
                        <Button x:Name="CaptureNowButton"
                                Grid.Column="2"
                                Content="Capture Now"
                                Click="CaptureNowButton_Click" />
                    </Grid>

                    <TextBlock Text="Feedback"
                               Style="{StaticResource LabelText}"
                               Margin="0,22,0,8" />
                    <Border BorderBrush="#6D28D9"
                            BorderThickness="1"
                            Background="#100B1D"
                            CornerRadius="6"
                            Padding="14">
                        <StackPanel>
                            <CheckBox x:Name="SoundCheckBox"
                                      Content="Play snip sound"
                                      Checked="SoundCheckBox_Changed"
                                      Unchecked="SoundCheckBox_Changed" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="42" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Volume"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MutedText}" />
                                <Slider x:Name="VolumeSlider"
                                        Grid.Column="2"
                                        VerticalAlignment="Center"
                                        ValueChanged="VolumeSlider_ValueChanged" />
                                <TextBlock x:Name="VolumeText"
                                           Grid.Column="4"
                                           VerticalAlignment="Center"
                                           TextAlignment="Right"
                                           Style="{StaticResource MutedText}" />
                            </Grid>
                            <CheckBox x:Name="NotificationCheckBox"
                                      Margin="0,12,0,0"
                                      Content="Show latest snip notification"
                                      Checked="NotificationCheckBox_Changed"
                                      Unchecked="NotificationCheckBox_Changed" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border Grid.Column="2"
                    Background="#171229"
                    BorderBrush="#3B1A66"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="20">
                <StackPanel>
                    <TextBlock Text="Current status" Style="{StaticResource LabelText}" />
                    <Border Background="#100B1D"
                            BorderBrush="#3B1A66"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="StatusText"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#F5F3FF" />
                            <TextBlock x:Name="CountdownText"
                                       Margin="0,8,0,0"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#C084FC" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Latest snip"
                               Style="{StaticResource LabelText}"
                               Margin="0,22,0,8" />
                    <Border Background="#100B1D"
                            BorderBrush="#3B1A66"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="LatestSnipNameText"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#F5F3FF" />
                            <TextBlock x:Name="LastSavedText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedText}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,18,0,0"
                   Text="The hotkey is active while this window is open. Pick points once, then press the hotkey from any focused app."
                   Foreground="#B9A8D8"
                   FontSize="12" />
    </Grid>
    </ScrollViewer>
</Window>
