<Window x:Class="PresetSnip.LatestSnipToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Latest Snip"
        Width="340"
        Height="112"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="Transparent">
    <Border Background="#F2171229"
            BorderBrush="#A855F7"
            BorderThickness="1"
            CornerRadius="8"
            Padding="14">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="40" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Width="40"
                    Height="40"
                    Background="#7C3AED"
                    CornerRadius="8">
                <TextBlock Text="SN"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="White" />
            </Border>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Text="Latest snip saved"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="#E9D5FF" />
                <TextBlock x:Name="FileNameText"
                           Margin="0,5,0,0"
                           FontSize="14"
                           FontWeight="Bold"
                           Foreground="#F5F3FF"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="FolderText"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#B9A8D8"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
